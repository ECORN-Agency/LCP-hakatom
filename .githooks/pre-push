#!/bin/sh
# Pre-push hook: run the unit suite before anything leaves the machine.
# Versioned in the repo and wired up via `core.hooksPath=.githooks`
# (see `npm run hooks:install`). Free, no CI service required.
#
# Skip in an emergency with:  git push --no-verify

echo "▶ pre-push: running unit tests…"

if ! npm run test --silent; then
  echo ""
  echo "✗ Tests failed — push aborted."
  echo "  Fix the failures, or bypass with: git push --no-verify"
  exit 1
fi

echo "✓ Tests passed — pushing."
exit 0
