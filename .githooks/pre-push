#!/bin/sh
# Pre-push hook: typecheck + run the unit suite before anything leaves the
# machine. Versioned in the repo and wired up via `core.hooksPath=.githooks`
# (see `npm run hooks:install`). Free, no CI service required.
#
# Skip in an emergency with:  git push --no-verify

echo "▶ pre-push: typechecking…"

if ! npm run typecheck --silent; then
  echo ""
  echo "✗ Typecheck failed — push aborted."
  echo "  Fix the type errors, or bypass with: git push --no-verify"
  exit 1
fi

echo "▶ pre-push: running unit tests…"

if ! npm run test --silent; then
  echo ""
  echo "✗ Tests failed — push aborted."
  echo "  Fix the failures, or bypass with: git push --no-verify"
  exit 1
fi

echo "✓ Typecheck + tests passed — pushing."
exit 0
