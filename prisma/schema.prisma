// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Change {
  id         String   @id @default(cuid())
  shop       String
  type       String
  occurredAt DateTime
  receivedAt DateTime @default(now())
  entityType String?
  entityId   String?
  summary    String
  payload    Json?
  // Shopify's X-Shopify-Webhook-Id header — unique per delivery attempt.
  // We dedupe retries by this. Nullable for backfill / manual events / legacy rows.
  webhookId  String?  @unique
  createdAt  DateTime @default(now())

  @@index([shop, occurredAt])
}

// Inbound webhook queue. Each row is one delivery from Shopify. Webhook
// handlers do the bare minimum (verify HMAC → enqueue → 200 OK) so we stay
// well under Shopify's 5s timeout even if downstream DB writes get slow.
// A separate worker endpoint pulls rows off this table and runs the actual
// topic-specific processing (dedup, snapshot diff, Change.create, …).
model WebhookJob {
  id          String    @id @default(cuid())
  shop        String
  topic       String
  webhookId   String    @unique // X-Shopify-Webhook-Id, deduplicates retries
  payload     Json
  status      String    @default("pending") // pending | processing | completed | failed
  attempts    Int       @default(0)
  errorMessage String?
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  @@index([status, createdAt])
  @@index([shop, createdAt])
}

// Per-shop housekeeping state. Right now: tracks whether the Web Pixel has
// already been activated for the shop so we don't re-create it on every load.
// Expand as more shop-level toggles arrive.
model ShopConfig {
  id                 String    @id @default(cuid())
  shop               String    @unique
  pixelActivatedAt   DateTime?
  pixelId            String?
  pixelLastError     String?
  // Per-shop backfill lock — set when a backfill is in flight, cleared
  // when it finishes. The UI / API refuses concurrent backfills for the
  // same shop, so two users clicking Backfill don't waste API quota.
  backfillStartedAt  DateTime?
  backfillFinishedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// Storefront analytics events forwarded from the Web Pixel extension running
// in the customer-facing sandbox iframe. Unlike orders webhooks (which lag by
// the time it takes a customer to pay), these arrive in seconds and let us
// measure conversion / cart abandonment / Web Vitals around a theme publish.
//
// Payload is intentionally slim and PII-free.
model PixelEvent {
  id         String   @id @default(cuid())
  shop       String
  eventName  String   // page_viewed | product_viewed | cart_viewed | product_added_to_cart | checkout_started | checkout_completed
  occurredAt DateTime
  receivedAt DateTime @default(now())
  productId  String?
  variantId  String?
  totalAmount Float?
  data       Json?

  @@index([shop, eventName, occurredAt])
  @@index([shop, occurredAt])
}

// User-configured alert rules. The cron worker evaluates recent Change rows
// against each enabled rule and dispatches a notification through `channel`.
//
// minLabel    — match threshold: "negative" or "strong_negative" (or "any").
// minConfidence — match threshold: "low" / "medium" / "high".
//   evaluation passes when the computed rec's strength >= minLabel AND
//   confidence >= minConfidence.
//
// evaluationDelayMin — wait this many minutes after the event before computing
// the recommendation, so the after-window has data to look at.
model AlertRule {
  id                 String   @id @default(cuid())
  shop               String
  channel            String   @default("email")  // "email" | "slack" (slack TBD)
  destination        String                       // email address or webhook URL
  minLabel           String   @default("strong_negative")
  minConfidence      String   @default("medium")
  enabled            Boolean  @default(true)
  evaluationDelayMin Int      @default(30)
  windowMinutes      Int      @default(1440)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([shop, enabled])
}

// One row per (rule, change) that fired. Guarantees we never send the same
// alert twice for the same event, and lets us audit what was delivered.
model AlertDelivery {
  id             String   @id @default(cuid())
  ruleId         String
  shop           String
  changeId       String
  recommendation Json
  channel        String
  destination    String
  status         String   // "sent" | "failed" | "skipped"
  errorMessage   String?
  deliveredAt    DateTime @default(now())

  @@unique([ruleId, changeId])
  @@index([shop, deliveredAt])
}

// Latest known list of files in a theme, used to diff against next
// themes/update so we can tell *which* files merchant changed.
// Stored as JSON array of { filename, checksumMd5, updatedAt, size } —
// no file body (keeps the row small even for themes with 1000+ files).
model ThemeSnapshot {
  id        String   @id @default(cuid())
  shop      String
  themeId   String
  files     Json
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([shop, themeId])
}

// Latest known state of a product per shop. Used to compute diffs between
// successive Shopify products/update webhooks (Shopify sends full state, not
// a diff — and often sends multiple webhooks for a single merchant edit).
//
// Upsert per (shop, productId) on every products/* webhook; delete on
// products/delete. Snapshot stores the fields we actually diff against —
// trim the JSON, don't dump the whole payload.
model ProductSnapshot {
  id        String   @id @default(cuid())
  shop      String
  productId String
  snapshot  Json
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([shop, productId])
  @@index([shop, updatedAt])
}

model MetricBucket {
  id            String   @id @default(cuid())
  shop          String
  bucketAt      DateTime
  bucketMinutes Int      @default(10)
  orders        Int
  revenue       Float
  createdAt     DateTime @default(now())

  @@unique([shop, bucketAt])
  @@index([shop, bucketAt])
  // Keep underlying DB table name to avoid data loss on existing prod data.
  // Drop @@map and run a proper migration when ready to rename the actual table.
  @@map("DailyMetric")
}
