// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Change {
  id         String   @id @default(cuid())
  shop       String
  type       String
  occurredAt DateTime
  receivedAt DateTime @default(now())
  entityType String?
  entityId   String?
  summary    String
  payload    Json?
  // Shopify's X-Shopify-Webhook-Id header — unique per delivery attempt.
  // We dedupe retries by this. Nullable for backfill / manual events / legacy rows.
  webhookId  String?  @unique
  createdAt  DateTime @default(now())

  @@index([shop, occurredAt])
}

// Latest known state of a product per shop. Used to compute diffs between
// successive Shopify products/update webhooks (Shopify sends full state, not
// a diff — and often sends multiple webhooks for a single merchant edit).
//
// Upsert per (shop, productId) on every products/* webhook; delete on
// products/delete. Snapshot stores the fields we actually diff against —
// trim the JSON, don't dump the whole payload.
model ProductSnapshot {
  id        String   @id @default(cuid())
  shop      String
  productId String
  snapshot  Json
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([shop, productId])
  @@index([shop, updatedAt])
}

model MetricBucket {
  id            String   @id @default(cuid())
  shop          String
  bucketAt      DateTime
  bucketMinutes Int      @default(10)
  orders        Int
  revenue       Float
  createdAt     DateTime @default(now())

  @@unique([shop, bucketAt])
  @@index([shop, bucketAt])
  // Keep underlying DB table name to avoid data loss on existing prod data.
  // Drop @@map and run a proper migration when ready to rename the actual table.
  @@map("DailyMetric")
}
